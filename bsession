#!/usr/bin/env bash
# Client-side wrapper for session.py running inside the agent-browser container.
set -euo pipefail

CONTAINER="agent-browser"
SESSION_PY="python3 /app/session.py"

# Check container is running
if ! docker inspect -f '{{.State.Running}}' "$CONTAINER" &>/dev/null; then
    echo "Container '$CONTAINER' is not running. Start it with: docker compose up -d" >&2
    exit 1
fi

exec docker exec -i "$CONTAINER" $SESSION_PY "$@"
